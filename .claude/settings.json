{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": ["Bash", "Edit", "Write", "Read", "WebFetch", "WebSearch"],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf $HOME/*)"
    ],
    "ask": [
      "Bash(git push --force*)",
      "Bash(git push -f*)"
    ]
  },
  "doneMeansMerged": true
}
